# piighost-api configuration
# Copy to .env and adjust values as needed:
#   cp .env.example .env

# ── Server ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# ── Pipeline ────────────────────────────────────────────
# Import path in module:variable format.
# The module must be importable (mounted via volume or in PYTHONPATH).
PIPELINE_PATH=pipeline:pipeline

# ── Redis ───────────────────────────────────────────────
# URL used by the API to connect to Redis (cache backend).
REDIS_URL=redis://redis:6379
# Host port exposed by the Redis container.
REDIS_PORT=6379

# ── Authentication (optional) ──────────────────────────
# Leave empty to disable auth (development mode).
# When both values are set, all endpoints require a Bearer token.
#
# Generate a pepper and an API key with keyshield:
#   uv run keyshield pepper          # outputs a random pepper
#   uv run keyshield hash <pepper>   # outputs a hashed API key + raw key
#
SECRET_PEPPER=
API_KEY=

# ── Runtime extras ─────────────────────────────────────
# Installed by entrypoint.sh inside the container at startup. Use this to
# pull the SDK matching the observation backend you enable below without
# rebuilding the image. Example: EXTRA_PACKAGES="piighost[langfuse]".
EXTRA_PACKAGES=

# ── Observation (optional) ─────────────────────────────
# Enable exactly ONE backend by setting its primary credential.
# If multiple backends are configured, the server fails fast at boot.
#
# Langfuse:
#   - local dev:  `uv sync --extra langfuse`
#   - docker:     EXTRA_PACKAGES="piighost[langfuse]"
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
#
# Opik:
#   - local dev:  `uv sync --extra opik`
#   - docker:     EXTRA_PACKAGES="piighost[opik]"
# OPIK_API_KEY=
# OPIK_WORKSPACE=
